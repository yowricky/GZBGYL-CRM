# Local development examples only. Do not use these values in production.
POSTGRES_DB=crm
POSTGRES_USER=crm
POSTGRES_PASSWORD=local-crm-password
DB_URL=jdbc:postgresql://localhost:5432/crm

REDIS_HOST=localhost
REDIS_PORT=6379

SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAME_SITE=lax

MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=crm-attachments
MINIO_ACCESS_KEY=crm-local-access
MINIO_SECRET_KEY=crm-local-secret

# UNSAFE placeholder for local bootstrap only. It must be changed before use.
INITIAL_ADMIN_PASSWORD=CHANGE-ME-UNSAFE
