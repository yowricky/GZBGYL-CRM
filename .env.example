# UNSAFE local development examples only. Change every password and secret before use.
POSTGRES_DB=crm
POSTGRES_MIGRATION_USER=crm_migration
POSTGRES_MIGRATION_PASSWORD=CHANGE-ME-UNSAFE-POSTGRES-MIGRATION
CRM_APP_PASSWORD=CHANGE-ME-UNSAFE-CRM-APP
DB_URL=jdbc:postgresql://localhost:5432/crm

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE-ME-UNSAFE-REDIS

SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAME_SITE=lax
CSRF_COOKIE_SECURE=false
CSRF_COOKIE_SAME_SITE=lax
SESSION_REDIS_NAMESPACE=crm:session:v1
SESSION_SECURITY_NAMESPACE=crm:security:v1:generation

MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=crm-attachments
MINIO_ROOT_USER=crm-local-root
MINIO_ROOT_PASSWORD=CHANGE-ME-UNSAFE-MINIO-ROOT
MINIO_APP_ACCESS_KEY=crm-local-app
MINIO_APP_SECRET_KEY=CHANGE-ME-UNSAFE-MINIO-APP

# UNSAFE local bootstrap password only. Change before any real deployment.
INITIAL_ADMIN_PASSWORD=Admin#ChangeMe123
